{
  "entities": {
    "Campaign": {
      "title": "Campaign",
      "description": "A donation campaign",
      "type": "object",
      "properties": {
        "title": { "type": "string", "description": "The title of the campaign" },
        "description": { "type": "string", "description": "The description of the campaign" },
        "active": { "type": "boolean", "description": "Whether the campaign is active" },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the campaign was created" }
      },
      "required": ["title", "active", "createdAt"]
    },
    "Donor": {
      "title": "Donor",
      "description": "A donor record",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "The name of the donor" },
        "phone": { "type": "string", "description": "The phone number of the donor" },
        "email": { "type": "string", "format": "email", "description": "The email of the donor" },
        "amount": { "type": "number", "description": "The donation amount" },
        "campaignId": { "type": "string", "description": "The ID of the campaign" },
        "timestamp": { "type": "string", "format": "date-time", "description": "When the donation was recorded" },
        "emailedInBatch": { "type": "boolean", "description": "Whether the donor has been included in a batch email" }
      },
      "required": ["name", "phone", "amount", "timestamp", "emailedInBatch"]
    }
  },
  "firestore": {
    "/campaigns/{campaignId}": {
      "schema": "Campaign",
      "description": "A collection of campaigns"
    },
    "/donors/{donorId}": {
      "schema": "Donor",
      "description": "A collection of donor records"
    }
  }
}
